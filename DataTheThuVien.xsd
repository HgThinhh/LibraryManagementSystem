                <SelectCommand>
                  <DbCommand CommandType="Text" ModifiedByUser="true">
                    <CommandText>/* thẻ mới cấp hôm nay*/
SELECT  t.MaThe, t.NgayCap, t.NgayHetHan, t.TrangThai, dg.MaDocGia, dg.HoTen AS TenDocGia, dg.DiaChi, dg.Email, dg.DienThoai
